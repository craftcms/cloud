{
  "name": "craftcms/cloud-ops",
  "description": "Craft Cloud infrastructure and runtime extension",
  "type": "yii2-extension",
  "license": "proprietary",
  "require": {
    "php": "^8.2",
    "craftcms/cms": "^4.6 || ^5.0",
    "bref/bref": "^2.0",
    "bref/extra-php-extensions": "^1.0",
    "craftcms/yii2-cache-cascade": "^1.0",
    "yiisoft/yii2-redis": "^2.0",
    "yiisoft/yii2-queue": "^2.3.7",
    "aws/aws-sdk-php": "^3.342.6",
    "craftcms/flysystem": "^1 || ^2",
    "league/flysystem-aws-s3-v3": "^3.15",
    "league/uri": "^7",
    "league/uri-components": "^7",
    "illuminate/collections": "^11.0 || ^12.0",
    "phlak/semver": "^4.1",
    "composer/semver": "^3.4",
    "guzzlehttp/psr7": "^2.8",
    "psr/http-message": "^2.0",
    "samdark/yii2-psr-log-target": "^1.1",
    "99designs/http-signatures": "^4.0",
    "symfony/process": "^6 || ^7"
  },
  "autoload": {
    "psr-4": {
      "craft\\cloud\\ops\\": "src/"
    },
    "files": [
      "autoload.php"
    ]
  },
  "extra": {
    "branch-alias": {
      "dev-main": "1.x-dev"
    },
    "bootstrap": "craft\\cloud\\ops\\Module"
  },
  "config": {
    "allow-plugins": {
      "yiisoft/yii2-composer": true
    }
  }
}
