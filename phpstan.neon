includes:
    - vendor/craftcms/phpstan/phpstan.neon

parameters:
    level: 5
    paths:
        - src
    ignoreErrors:
        -
            path: src/imagetransforms/ImageTransformer.php
            identifier: argument.type
            reportUnmatched: false
        -
            path: src/imagetransforms/ImageTransformer.php
            identifier: arguments.count
            reportUnmatched: false
